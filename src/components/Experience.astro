---
import { experience, education } from '../data/profile';
---

<section id="experience">
  <div class="wrap">
    <div class="sec-head">
      <span class="num">II</span>
      <span class="rule"></span>
      <span class="label">Experience</span>
    </div>

    <h2 class="sec-title">19+ years — from national systems to AI products</h2>

    <div class="rows">
      {experience.map((job) => (
        <div class="row" data-reveal>
          <div>
            <p class="period">{job.period}</p>
            <p class="place">{job.location}</p>
          </div>
          <div>
            <h3>{job.role}</h3>
            <p class="org">{job.company}</p>
            <p class="note">{job.points.join(' ')}</p>
          </div>
        </div>
      ))}

      <div class="row" data-reveal>
        <div>
          <p class="period">{education.period}</p>
        </div>
        <div>
          <h3>{education.degree}</h3>
          <p class="org">{education.school}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  section {
    padding: 120px 0;
  }

  h2 {
    max-width: 840px;
  }

  .rows {
    margin-top: 40px;
  }

  .row {
    display: grid;
    grid-template-columns: 0.32fr 0.68fr;
    gap: 56px;
    padding: 34px 0;
    border-top: 1px solid var(--line);
  }

  .period {
    font-size: 12.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
  }

  .place {
    font-size: 13px;
    color: var(--faint);
    margin-top: 6px;
  }

  .row h3 {
    font-size: 26px;
    line-height: 1.15;
  }

  .org {
    font-size: 14px;
    color: var(--muted);
    margin-top: 4px;
    letter-spacing: 0.02em;
  }

  .note {
    font-size: 15.5px;
    line-height: 1.6;
    color: var(--muted);
    margin-top: 12px;
    max-width: 620px;
  }

  @media (max-width: 768px) {
    .row {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }
</style>
