---
import { experience, education } from '../data/profile';
---

<section id="experience">
  <div class="container">
    <p class="eyebrow">02 — Experience</p>
        <h2 class="section-title">19+ years, from national systems to AI products</h2>
    <p class="section-lead">
      Government-scale platforms in Dhaka, database tooling in Stockholm, assessment systems for
      global certification bodies — and a company of my own.
    </p>

    <ol class="timeline">
      {experience.map((job) => (
        <li class="entry" data-reveal>
          <div class="marker" aria-hidden="true"></div>
          <div class="meta">
            <span class="period">{job.period}</span>
            <span class="location">{job.location}</span>
          </div>
          <div class="body">
            <h3 class="role">{job.role}</h3>
            <p class="company">{job.company}</p>
            <ul class="points">
              {job.points.map((pt) => (
                <li>{pt}</li>
              ))}
            </ul>
          </div>
        </li>
      ))}
    </ol>

    <div class="education" data-reveal>
      <span class="edu-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 3 1 9l11 6 9-4.91V17h2V9L12 3zM5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82z"/>
        </svg>
      </span>
      <div>
        <p class="edu-degree">{education.degree}</p>
        <p class="edu-school">{education.school} · {education.period}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .timeline {
    list-style: none;
    padding: 0;
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 195px;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: var(--line);
  }

  .entry {
    display: grid;
    grid-template-columns: 170px 50px 1fr;
    padding: 1.4rem 0;
  }

  .meta {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    text-align: right;
  }

  .period {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent-bright);
  }

  .location {
    font-size: 0.78rem;
    color: var(--faint);
  }

  .marker {
    grid-column: 2;
    grid-row: 1;
    justify-self: center;
    width: 11px;
    height: 11px;
    margin-top: 5px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--accent);
    box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.12);
  }

  .role {
    font-size: 1.1rem;
  }

  .company {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
    margin-top: 0.15rem;
  }

  .points {
    margin: 0.6rem 0 0;
    padding-left: 1.1rem;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .points li + li {
    margin-top: 0.35rem;
  }

  .education {
    margin-top: 2.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.2rem 1.4rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.03), transparent);
    width: fit-content;
  }

  .edu-icon {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--accent-soft);
    color: var(--accent-bright);
    flex-shrink: 0;
  }

  .edu-degree {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .edu-school {
    color: var(--muted);
    font-size: 0.85rem;
  }

  @media (max-width: 760px) {
    .timeline::before {
      left: 5px;
    }

    .entry {
      grid-template-columns: 1fr;
      padding-left: 28px;
      position: relative;
    }

    .marker {
      position: absolute;
      left: 0;
      top: 1.65rem;
      grid-column: auto;
    }

    .meta {
      text-align: left;
      flex-direction: row;
      gap: 0.75rem;
      margin-bottom: 0.4rem;
    }
  }
</style>
