---
import { person, stats } from '../data/profile';
---

<section class="wrap">
  <div class="hero">
    <div class="photo" data-reveal>
      <img
        src="/sohel-rana.jpg"
        alt={person.name}
        width="1200"
        height="1500"
        loading="eager"
        fetchpriority="high"
      />
      <div class="vignette" aria-hidden="true"></div>
      <div class="baseline" aria-hidden="true"></div>
    </div>

    <div class="intro" data-reveal>
      <div class="eyebrow-line">{person.headline}</div>

      <h1>{person.nameLines[0]}<br />{person.nameLines[1]}</h1>

      <p class="summary">{person.summary}</p>

      <div class="actions">
        <a class="btn-accent" href={`mailto:${person.email}`}>Get in touch</a>
        <a class="btn-line" href={person.cvFile} download>Download CV ↓</a>
      </div>

      <div class="socials">
        <a href={person.linkedin} target="_blank" rel="noopener">LinkedIn ↗</a>
        <a href={person.github} target="_blank" rel="noopener">GitHub ↗</a>
      </div>
    </div>
  </div>

  <div class="stat-band" data-reveal>
    {stats.map((s) => (
      <div>
        <div class="figure">{s.value}</div>
        <div class="label">{s.label}</div>
      </div>
    ))}
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 0.82fr 1.18fr;
    gap: 72px;
    align-items: center;
    padding-top: 92px;
  }

  .photo {
    position: relative;
  }
  .photo img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: top center;
    filter: grayscale(0.32) contrast(1.02) brightness(0.96);
    border: 1px solid var(--line);
  }
  .vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    box-shadow: inset 0 -120px 90px -60px rgba(0, 0, 0, 0.55);
  }
  .baseline {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    background: var(--accent);
  }

  .eyebrow-line {
    font-size: 12.5px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
    margin-bottom: 24px;
  }
  h1 {
    font-size: clamp(52px, 9vw, 104px);
    line-height: 0.98;
  }
  .summary {
    max-width: 560px;
    margin-top: 30px;
    font-size: 17.5px;
    line-height: 1.64;
    color: var(--muted);
  }
  .summary strong {
    color: var(--ink);
    font-weight: inherit;
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 36px;
  }
  .socials {
    display: flex;
    gap: 26px;
    margin-top: 24px;
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--faint);
  }
  .socials a {
    transition: color var(--t);
  }
  .socials a:hover {
    color: var(--accent);
  }

  .stat-band {
    margin-top: 72px;
  }

  @media (max-width: 1024px) {
    .hero {
      gap: 48px;
    }
  }

  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      padding-top: 56px;
    }
    .photo img {
      max-height: 420px;
    }
  }

  /* Below 640px the global `section` rule supplies 64px of block padding.
     Drop the hero's own top padding so the two don't stack into ~120px. */
  @media (max-width: 640px) {
    .hero {
      padding-top: 0;
    }
  }
</style>
