---
import { company } from '../data/profile';
---

<section id="nerddevs">
  <div class="container">
    <div class="banner" data-reveal>
      <div class="banner-glow" aria-hidden="true"></div>

      <p class="eyebrow">04 — My Company</p>
      <h2 class="section-title">
        Building something? <span class="accent">NerdDevs</span> can build it with you.
      </h2>
      <p class="tagline">{company.tagline}</p>
      <p class="blurb">{company.blurb}</p>

      <div class="stats">
        {company.stats.map((s) => (
          <div class="stat">
            <span class="value">{s.value}</span>
            <span class="label">{s.label}</span>
          </div>
        ))}
      </div>

      <div class="actions">
        <a class="btn btn-primary" href={company.url} target="_blank" rel="noopener">
          {company.cta} →
        </a>
        <a class="btn btn-ghost" href={`mailto:${company.email}`}>{company.email}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .banner {
    position: relative;
    overflow: hidden;
    padding: 3rem;
    border-radius: 20px;
    border: 1px solid rgba(249, 115, 22, 0.35);
    background:
      linear-gradient(135deg, rgba(249, 115, 22, 0.09), transparent 45%),
      linear-gradient(180deg, var(--card), var(--surface));
  }

  .banner-glow {
    position: absolute;
    bottom: -180px;
    right: -120px;
    width: 420px;
    height: 420px;
    border-radius: 50%;
    background: radial-gradient(closest-side, rgba(249, 115, 22, 0.14), transparent 70%);
    pointer-events: none;
  }

  .accent {
    color: var(--accent-bright);
  }

  .tagline {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent);
    letter-spacing: 0.04em;
    margin-bottom: 1rem;
  }

  .blurb {
    color: var(--muted);
    max-width: 720px;
  }

  .stats {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 2.5rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
  }

  .value {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--text);
  }

  .label {
    font-size: 0.8rem;
    color: var(--muted);
  }

  .actions {
    margin-top: 2.25rem;
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
  }

  @media (max-width: 640px) {
    .banner {
      padding: 2rem 1.5rem;
    }

    .stats {
      gap: 1.5rem 2rem;
    }
  }
</style>
