---
import { company } from '../data/profile';
---

<section class="band" id="nerddevs">
  <div class="wrap">
    <div class="sec-head">
      <span class="num">IV</span>
      <span class="rule"></span>
      <span class="label">NerdDevs</span>
    </div>

    <h2 class="sec-title" data-reveal>Building something? NerdDevs can build it with you.</h2>
    <p class="blurb sec-lead" data-reveal>{company.blurb}</p>

    <div class="stat-band" data-reveal>
      {company.stats.map((s) => (
        <div>
          <span class="figure">{s.value}</span>
          <span class="label">{s.label}</span>
        </div>
      ))}
    </div>

    <a class="btn-accent" href={company.url} target="_blank" rel="noopener" data-reveal>
      {company.cta} →
    </a>
  </div>
</section>

<style>
  .band {
    background: var(--surface);
    margin-top: 96px;
    padding-block: 88px;
  }

  h2 {
    /* Design sizes this section's heading at 50px. */
    font-size: clamp(30px, 4.8vw, 50px);
    line-height: 1.05;
    max-width: 900px;
  }

  .blurb {
    max-width: 680px;
  }

  .stat-band {
    margin-top: 40px;
  }

  .btn-accent {
    margin-top: 34px;
    display: inline-block;
  }
</style>
