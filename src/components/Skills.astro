---
import { skills, person } from '../data/profile';
---

<section id="skills">
  <div class="container">
    <p class="eyebrow">03 — Skills</p>
    <h2 class="section-title">The stack I build with</h2>
    <p class="section-lead">
      Technologies matched to the problem — never the other way around.
    </p>

    <div class="grid">
      {skills.map((group) => (
        <div class="group" data-reveal>
          <h3 class="group-name">{group.group}</h3>
          <div class="items">
            {group.items.map((item) => (
              <span class="chip">{item}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="principles" data-reveal>
      {person.principles.map((p) => (
        <p class="principle">
          <span class="tick" aria-hidden="true">✓</span>
          {p}
        </p>
      ))}
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .group {
    padding: 1.4rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: linear-gradient(180deg, var(--card), var(--surface));
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .group:hover {
    border-color: rgba(249, 115, 22, 0.35);
    transform: translateY(-3px);
  }

  .group-name {
    font-size: 0.95rem;
    color: var(--accent-bright);
    margin-bottom: 0.9rem;
  }

  .items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .principles {
    margin-top: 2.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 2.5rem;
  }

  .principle {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .tick {
    color: var(--accent);
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 560px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
