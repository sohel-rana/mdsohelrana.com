---
import { projects } from '../data/profile';

const featured = projects.filter((p) => p.featured);
const more = projects.filter((p) => !p.featured);
---

<section id="work">
  <div class="wrap">
    <div class="sec-head">
      <span class="num">I</span>
      <span class="rule"></span>
      <span class="label">Featured Work</span>
    </div>

    <h2 class="sec-title">Products used by millions</h2>
    <p class="lead sec-lead">
      Platforms I’ve architected and shipped — client work and NerdDevs’ own products, from AI
      assistants and messaging backends to assessment systems trusted by global certification
      bodies. Some clients stay unnamed; that discretion is part of the engagement.
    </p>

    <div class="cards">
      {featured.map((p) => (
        <article class="card" data-reveal>
          <div class="card-top">
            <span class="idx">{p.index}</span>
            <span class="period">{p.period}{p.nda ? ' · NDA' : ''}</span>
          </div>

          <h3>{p.name}</h3>
          <p class="role">{p.role}</p>
          <p class="blurb">{p.description}</p>
          <p class="metric">{p.impact}</p>

          <div class="tags">
            {p.tags.map((t) => (
              <span class="chip">{t}</span>
            ))}
          </div>

          {(p.live || p.caseStudy) && (
            <div class="links">
              {p.live && (
                <a href={p.live.url} target="_blank" rel="noopener">{p.live.label} ↗</a>
              )}
              {p.caseStudy && (
                <a href={p.caseStudy} target="_blank" rel="noopener">Case study →</a>
              )}
            </div>
          )}
        </article>
      ))}
    </div>

    <p class="more-label">More work</p>
    <div class="more">
      {more.map((p) => (
        <div class="more-row" data-reveal>
          <span class="more-name">{p.name}</span>
          <span class="more-role">{p.role}</span>
          <span class="more-period">{p.period}</span>
          <span class="more-metric">{p.impact}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  section {
    padding: 120px 0;
  }

  h2 {
    /* Design: 58px (= the shared .sec-title ceiling) at a tighter line-height. */
    line-height: 1.02;
    max-width: 820px;
  }

  .lead {
    max-width: 640px;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 26px;
    margin-top: 40px;
  }

  .card {
    background: var(--surface);
    border-top: 2px solid var(--accent);
    padding: 36px 34px;
    display: flex;
    flex-direction: column;
    transition: background var(--t);
  }

  .card:hover {
    background: var(--raised);
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .idx {
    font-family: var(--font-display);
    font-size: 26px;
    color: var(--faint);
  }

  .period {
    font-size: 11.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .card h3 {
    font-size: clamp(26px, 3vw, 32px);
    line-height: 1.08;
    margin-top: 16px;
  }

  .role {
    font-size: 12.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: 8px;
  }

  .blurb {
    margin-top: 16px;
    font-size: 15.5px;
    line-height: 1.6;
    color: var(--muted);
  }

  .metric {
    font-family: var(--font-display);
    font-size: 20px;
    color: var(--accent);
    margin-top: 20px;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 20px;
  }

  .links {
    display: flex;
    gap: 20px;
    margin-top: auto;
    padding-top: 20px;
    border-top: 1px solid var(--line);
    font-size: 12.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .links a {
    transition: color var(--t);
  }

  .links a:hover {
    color: var(--accent);
  }

  .more-label {
    margin-top: 64px;
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .more-row {
    display: grid;
    grid-template-columns: 1.1fr 1.2fr 0.9fr 1fr;
    gap: 24px;
    align-items: baseline;
    padding: 22px 0;
    border-top: 1px solid var(--line);
  }

  .more-name {
    font-family: var(--font-display);
    font-size: 23px;
    font-weight: 600;
  }

  .more-role {
    font-size: 14px;
    color: var(--muted);
  }

  .more-period {
    font-size: 12.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--faint);
  }

  .more-metric {
    font-size: 14px;
    color: var(--accent);
    text-align: right;
  }

  @media (max-width: 1024px) {
    .cards {
      grid-template-columns: 1fr;
    }

    .more-row {
      grid-template-columns: 1.1fr 1.2fr 0.9fr;
    }

    .more-metric {
      display: none;
    }
  }

  @media (max-width: 560px) {
    .more-row {
      grid-template-columns: 1fr 1fr;
      row-gap: 6px;
    }

    .more-name {
      grid-column: 1;
      grid-row: 1;
    }

    .more-role {
      grid-column: 2;
      grid-row: 1;
    }

    .more-period {
      grid-column: 1;
      grid-row: 2;
    }

    .more-metric {
      display: block;
      grid-column: 2;
      grid-row: 2;
      text-align: right;
    }
  }
</style>
