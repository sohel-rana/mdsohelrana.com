---
import { projects } from '../data/profile';
---

<section id="work">
  <div class="container">
    <p class="eyebrow">01 — Featured Work</p>
    <h2 class="section-title">Products used by millions</h2>
    <p class="section-lead">
      A selection of platforms I’ve architected and shipped — from AI assistants and messaging
      backends to national-scale assessment systems.
    </p>

    <div class="grid">
      {projects.map((p) => (
        <article class={`card ${p.featured ? 'featured' : ''}`} data-reveal>
          <div class="card-top">
            <span class="index">{p.index}</span>
            <span class="period">{p.period}</span>
          </div>

          <h3 class="card-title">
            {p.link ? (
              <a href={p.link} target="_blank" rel="noopener">
                {p.name}
                <svg class="ext" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path d="M7 17L17 7M9 7h8v8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            ) : (
              p.name
            )}
          </h3>

          <p class="card-role">{p.role}</p>
          <p class="card-desc">{p.description}</p>

          <p class="impact">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M13 2 3 14h7l-1 8 10-12h-7l1-8z"/>
            </svg>
            {p.impact}
          </p>

          <div class="tags">
            {p.tags.map((t) => (
              <span class="chip">{t}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1.25rem;
  }

  .card {
    grid-column: span 2;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding: 1.6rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: linear-gradient(180deg, var(--card), var(--surface));
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .card.featured {
    grid-column: span 3;
  }

  .card:hover {
    transform: translateY(-4px);
    border-color: rgba(249, 115, 22, 0.45);
    box-shadow: 0 18px 40px -20px rgba(0, 0, 0, 0.7);
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .index {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
  }

  .period {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--faint);
  }

  .card-title {
    font-size: 1.25rem;
  }

  .card-title a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: color 0.15s ease;
  }

  .card-title a:hover {
    color: var(--accent-bright);
  }

  .ext {
    opacity: 0.5;
  }

  .card-role {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--muted);
    letter-spacing: 0.03em;
  }

  .card-desc {
    color: var(--muted);
    font-size: 0.93rem;
    flex-grow: 1;
  }

  .impact {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--accent-bright);
    background: var(--accent-soft);
    border-radius: 8px;
    padding: 0.55rem 0.8rem;
    width: fit-content;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.35rem;
  }

  @media (max-width: 980px) {
    .card,
    .card.featured {
      grid-column: span 3;
    }
  }

  @media (max-width: 640px) {
    .card,
    .card.featured {
      grid-column: span 6;
    }
  }
</style>
