---
import { projects } from '../data/profile';
---

<section id="work">
  <div class="container">
    <p class="eyebrow">01 — Featured Work</p>
    <h2 class="section-title">Products used by millions</h2>
    <p class="section-lead">
      Platforms I’ve architected and shipped — client work and NerdDevs’ own products, from AI
      assistants and messaging backends to assessment systems trusted by global certification
      bodies. Some clients stay unnamed; that discretion is part of the engagement.
    </p>

    <div class="grid">
      {projects.map((p) => (
        <article class={`card ${p.featured ? 'featured' : ''}`} data-reveal>
          <div class="card-top">
            <span class="index">{p.index}</span>
            <span class="top-right">
              {p.nda && <span class="nda">Client under NDA</span>}
              <span class="period">{p.period}</span>
            </span>
          </div>

          <h3 class="card-title">
            {p.link ? (
              <a href={p.link} target="_blank" rel="noopener">
                {p.name}
                <svg class="ext" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path d="M7 17L17 7M9 7h8v8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            ) : (
              p.name
            )}
          </h3>

          <p class="card-role">{p.role}</p>
          <p class="card-desc">{p.description}</p>

          <ul class="highlights">
            {p.highlights.map((h) => (
              <li>{h}</li>
            ))}
          </ul>

          <p class="impact">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M13 2 3 14h7l-1 8 10-12h-7l1-8z"/>
            </svg>
            {p.impact}
          </p>

          <div class="tags">
            {p.tags.map((t) => (
              <span class="chip">{t}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1.25rem;
  }

  .card {
    grid-column: span 2;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding: 1.6rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: linear-gradient(180deg, var(--card), var(--surface));
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .card.featured {
    grid-column: span 3;
  }

  .card:hover {
    transform: translateY(-4px);
    border-color: rgba(249, 115, 22, 0.45);
    box-shadow: 0 18px 40px -20px rgba(0, 0, 0, 0.7);
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .index {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
  }

  .period {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--faint);
  }

  .top-right {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .nda {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent-bright);
    border: 1px solid rgba(249, 115, 22, 0.4);
    border-radius: 999px;
    padding: 0.15rem 0.55rem;
    white-space: nowrap;
  }

  .card-title {
    font-size: 1.25rem;
  }

  .card-title a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: color 0.15s ease;
  }

  .card-title a:hover {
    color: var(--accent-bright);
  }

  .ext {
    opacity: 0.5;
  }

  .card-role {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--muted);
    letter-spacing: 0.03em;
  }

  .card-desc {
    color: var(--muted);
    font-size: 0.93rem;
  }

  .highlights {
    list-style: none;
    margin: 0.1rem 0 0;
    padding: 0;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .highlights li {
    position: relative;
    padding-left: 1.15rem;
    color: var(--muted);
    font-size: 0.86rem;
    line-height: 1.5;
  }

  .highlights li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  .impact {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--accent-bright);
    background: var(--accent-soft);
    border-radius: 8px;
    padding: 0.55rem 0.8rem;
    width: fit-content;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.35rem;
  }

  @media (max-width: 980px) {
    .card,
    .card.featured {
      grid-column: span 3;
    }
  }

  @media (max-width: 640px) {
    .card,
    .card.featured {
      grid-column: span 6;
    }
  }
</style>
