---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Contact from '../../components/Contact.astro';
import { getCollection, render } from 'astro:content';
import { site, person, company } from '../../data/profile';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const dateFmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const coverImage = post.data.image ?? site.ogImage;
const postUrl = `${site.url}/blog/${post.id}`;

const wordCount = post.body?.split(/\s+/).filter(Boolean).length ?? 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BlogPosting',
      '@id': `${postUrl}/#article`,
      headline: post.data.title,
      description: post.data.description,
      image: `${site.url}${coverImage}`,
      datePublished: post.data.pubDate.toISOString(),
      dateModified: post.data.pubDate.toISOString(),
      inLanguage: 'en',
      keywords: post.data.tags.join(', '),
      articleSection: post.data.tags[0] ?? 'Engineering',
      wordCount: wordCount || undefined,
      author: { '@id': `${site.url}/#person` },
      publisher: { '@id': `${company.url}/#organization` },
      mainEntityOfPage: postUrl,
      isPartOf: { '@id': `${site.url}/blog/#blog` },
      url: postUrl,
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${postUrl}/#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
        { '@type': 'ListItem', position: 2, name: 'Blog', item: `${site.url}/blog` },
        { '@type': 'ListItem', position: 3, name: post.data.title, item: postUrl },
      ],
    },
  ],
};
---

<Base
  title={`${post.data.title} — ${person.name}`}
  description={post.data.description}
  ogImage={coverImage}
  ogType="article"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <Nav />
  <main>
    <article class="post">
      <div class="wrap">
        <a class="back-link" href="/blog">← All posts</a>

        <p class="post-meta">
          <time datetime={post.data.pubDate.toISOString()}>{dateFmt(post.data.pubDate)}</time>
          <span class="sep">·</span>
          <span>{readingTime} min read</span>
        </p>

        <h1 class="post-title">{post.data.title}</h1>

        <div class="post-tags">
          {post.data.tags.map((t) => (
            <span class="chip">{t}</span>
          ))}
        </div>

        <div class="prose">
          <Content />
        </div>

        <div class="post-footer">
          <a class="btn-line" href="/blog">← Back to all posts</a>
          <a class="btn-accent" href={`mailto:${person.email}`}>Get in touch</a>
        </div>
      </div>
    </article>

    <Contact />
  </main>
</Base>

<style>
  .post {
    padding: 140px 0 40px;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 2.5rem;
    font-size: 14px;
    color: var(--muted);
    transition: color var(--t);
  }

  .back-link:hover {
    color: var(--accent);
  }

  .post-meta {
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 18px;
  }

  .post-meta .sep {
    margin: 0 0.5em;
  }

  .post-title {
    font-size: clamp(34px, 5.5vw, 56px);
    line-height: 1.04;
    max-width: 780px;
    margin-bottom: 28px;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 3rem;
  }

  .prose {
    max-width: 68ch;
    font-size: 17.5px;
    line-height: 1.7;
    color: var(--muted);
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(26px, 3.4vw, 34px);
    color: var(--ink);
    margin-top: 2.2em;
    margin-bottom: 0.5em;
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 24px;
    color: var(--ink);
    margin-top: 1.8em;
    margin-bottom: 0.4em;
  }

  .prose :global(p) {
    margin-bottom: 1.25em;
  }

  .prose :global(strong) {
    color: var(--ink);
    font-weight: 600;
  }

  .prose :global(a) {
    color: var(--accent);
    border-bottom: 1px solid var(--line);
    transition: border-color var(--t);
  }

  .prose :global(a:hover) {
    border-bottom-color: var(--accent);
  }

  .prose :global(blockquote) {
    border-left: 2px solid var(--accent);
    padding-left: 22px;
    margin: 1.6em 0;
    color: var(--ink);
    font-family: var(--font-display);
    font-size: 21px;
    line-height: 1.45;
  }

  .prose :global(code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.88em;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 2px;
    padding: 2px 6px;
  }

  .prose :global(pre) {
    background: var(--surface);
    border: 1px solid var(--line);
    padding: 20px;
    overflow-x: auto;
    margin: 1.6em 0;
  }

  .prose :global(pre code) {
    background: none;
    border: 0;
    padding: 0;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.3em;
    margin-bottom: 1.25em;
  }

  .prose :global(li) {
    margin-bottom: 0.5em;
  }

  .post-footer {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--line);
    max-width: 68ch;
  }
</style>
