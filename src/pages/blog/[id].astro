---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Contact from '../../components/Contact.astro';
import { getCollection, render } from 'astro:content';
import { site, person } from '../../data/profile';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const dateFmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const coverImage = post.data.image ?? site.ogImage;

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  image: `${site.url}${coverImage}`,
  datePublished: post.data.pubDate.toISOString(),
  author: { '@type': 'Person', name: person.name, url: site.url },
  publisher: { '@type': 'Organization', name: 'NerdDevs Ltd', url: 'https://nerddevs.com' },
  mainEntityOfPage: `${site.url}/blog/${post.id}`,
};
---

<Base
  title={`${post.data.title} — ${person.name}`}
  description={post.data.description}
  ogImage={coverImage}
  ogType="article"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
  </Fragment>

  <Nav />
  <main>
    <article class="post">
      <div class="container">
        <a class="back-link" href="/blog">← All posts</a>

        <p class="post-meta">
          <time datetime={post.data.pubDate.toISOString()}>{dateFmt(post.data.pubDate)}</time>
          <span class="sep">·</span>
          <span>{person.name}</span>
        </p>

        <h1 class="post-title">{post.data.title}</h1>

        <div class="post-tags">
          {post.data.tags.map((t) => (
            <span class="chip">{t}</span>
          ))}
        </div>

        <div class="prose">
          <Content />
        </div>

        <div class="post-footer">
          <a class="btn btn-ghost" href="/blog">← Back to all posts</a>
          <a class="btn btn-primary" href={`mailto:${person.email}`}>Get in touch</a>
        </div>
      </div>
    </article>

    <Contact />
  </main>
</Base>

<style>
  .post {
    padding: 160px 0 40px;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--muted);
    transition: color 0.15s ease;
  }

  .back-link:hover {
    color: var(--accent-bright);
  }

  .post-meta {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--faint);
    margin-bottom: 1rem;
  }

  .post-meta time {
    color: var(--accent);
  }

  .post-meta .sep {
    margin: 0 0.5rem;
  }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 4.4vw, 2.9rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    max-width: 780px;
    margin-bottom: 1.25rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .prose {
    max-width: 720px;
    color: var(--text);
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .prose :global(p) {
    margin-bottom: 1.4rem;
    color: var(--text);
  }

  .prose :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .prose :global(a) {
    color: var(--accent-bright);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose :global(h2) {
    font-size: 1.4rem;
    margin: 2.4rem 0 1rem;
  }

  .prose :global(h3) {
    font-size: 1.15rem;
    margin: 2rem 0 0.85rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.4rem 1.3rem;
    color: var(--text);
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose :global(blockquote) {
    border-left: 2px solid var(--accent);
    padding-left: 1.1rem;
    color: var(--muted);
    margin: 1.6rem 0;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: var(--surface);
    border: 1px solid var(--line);
    padding: 0.15em 0.4em;
    border-radius: 5px;
  }

  .post-footer {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--line);
    max-width: 720px;
  }
</style>
