---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Contact from '../../components/Contact.astro';
import { getCollection } from 'astro:content';
import { site, person } from '../../data/profile';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const dateFmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const blogPageDescription =
  'Notes on AI product development, SaaS architecture, EdTech, and engineering leadership from Md. Sohel Rana, Founder & CEO of NerdDevs.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Blog',
      '@id': `${site.url}/blog/#blog`,
      url: `${site.url}/blog`,
      name: `Blog — ${person.name}`,
      description: blogPageDescription,
      inLanguage: 'en',
      isPartOf: { '@id': `${site.url}/#website` },
      author: { '@id': `${site.url}/#person` },
      blogPost: posts.map((post) => ({
        '@id': `${site.url}/blog/${post.id}/#article`,
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${site.url}/blog/#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
        { '@type': 'ListItem', position: 2, name: 'Blog', item: `${site.url}/blog` },
      ],
    },
  ],
};
---

<Base
  title={`Blog — ${person.name}`}
  description={blogPageDescription}
  ogImage={site.ogImage}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <Nav />
  <main>
    <section class="blog-hero">
      <div class="wrap">
        <div class="sec-head">
          <span class="rule"></span>
          <span class="label">Writing</span>
        </div>
        <h1 class="sec-title">Notes from building AI products and running an engineering team</h1>
        <p class="lead sec-lead">
          Field notes on AI product development, SaaS architecture, EdTech, cloud infrastructure and
          engineering leadership — drawn from what we actually ship at NerdDevs, not theory.
        </p>
      </div>
    </section>

    <section class="blog-list">
      <div class="wrap">
        <div class="posts">
          {posts.map((post) => (
            <a class="post" href={`/blog/${post.id}`} data-reveal>
              {post.data.image && <img src={post.data.image} alt="" loading="lazy" />}
              <div>
                <p class="post-meta">
                  <time datetime={post.data.pubDate.toISOString()}>{dateFmt(post.data.pubDate)}</time>
                </p>
                <h2>{post.data.title}</h2>
                <p class="post-desc">{post.data.description}</p>
                <div class="post-tags">
                  {post.data.tags.map((t) => (
                    <span class="chip">{t}</span>
                  ))}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <Contact />
  </main>
</Base>

<style>
  .blog-hero {
    padding: 100px 0 60px;
  }

  .blog-hero h1 {
    max-width: 880px;
  }

  .lead {
    max-width: 640px;
  }

  .blog-list {
    padding-bottom: 100px;
  }

  .post {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 32px;
    align-items: start;
    padding: 28px 0;
    border-top: 1px solid var(--line);
  }

  .post img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border: 1px solid var(--line);
    filter: grayscale(0.32) contrast(1.02) brightness(0.96);
    transition: filter 0.25s ease;
  }

  .post:hover img {
    filter: none;
  }

  .post h2 {
    font-size: clamp(24px, 3vw, 30px);
    line-height: 1.1;
    transition: color var(--t);
  }

  .post:hover h2 {
    color: var(--accent);
  }

  .post-meta {
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
  }

  .post-desc {
    color: var(--muted);
    font-size: 15.5px;
    margin-top: 12px;
    max-width: 620px;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }

  @media (max-width: 768px) {
    .post {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
</style>
